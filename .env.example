# PostgreSQL connection string (e.g. from Neon, Supabase, or local)
DATABASE_URL=

# Vercel Blob — get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=

# "pollinations" (free, no key) or "gemini" (requires GEMINI_API_KEY)
AI_PROVIDER=pollinations

# Only required if AI_PROVIDER=gemini
GEMINI_API_KEY=
