generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Generation {
  id        String   @id @default(cuid())
  sessionId String
  prompt    String
  styles    String[]
  imagePath String
  createdAt DateTime @default(now())

  @@index([sessionId])
}
